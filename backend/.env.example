# ─── MongoDB Atlas ───────────────────────────────────────────────
# Obtén este string en: Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/happybody?retryWrites=true&w=majority

# ─── Servidor ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS: URL exacta de tu frontend en Netlify ──────────────────
# En desarrollo puedes dejar * o http://localhost:5500
FRONTEND_URL=https://tu-sitio.netlify.app
